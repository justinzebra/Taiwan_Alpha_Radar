# Optional overrides for `docker compose up`.
# Copy to .env and fill in if you want real LLM-generated reports.

# AI provider: mock (default, no key needed) | openai | anthropic
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# End-of-day market data: official_close (TWSE/TPEx) | mock
DATA_PROVIDER=official_close
MARKET_HISTORY_DAYS=180
PREDICTION_LOOKBACK_DAYS=120
